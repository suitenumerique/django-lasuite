# Django core
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,web

# OIDC Provider settings
# Fill these in with your real OIDC provider details.
# If you only want to test the resource-server client against the mock server,
# you can leave the OIDC endpoints empty; the login flow simply won't work.
OIDC_OP_URL=
OIDC_OP_AUTHORIZATION_ENDPOINT=
OIDC_OP_TOKEN_ENDPOINT=
OIDC_OP_USER_ENDPOINT=
OIDC_OP_LOGOUT_ENDPOINT=
OIDC_OP_JWKS_ENDPOINT=
OIDC_RP_CLIENT_ID=
OIDC_RP_CLIENT_SECRET=
OIDC_RP_SCOPES=openid email profile
OIDC_RP_SIGN_ALGO=RS256
OIDC_VERIFY_SSL=true
OIDC_TIMEOUT=10

# Token encryption key (must be exactly 32 bytes for Fernet)
OIDC_STORE_REFRESH_TOKEN_KEY=demo-key-must-be-32-bytes-long!!

# Resource Server to consume
# When running via compose.yaml this defaults to the mock resource server.
# Override it here if you want to point at a real resource server.
# RESOURCE_SERVER_BASE_URL=http://mock-resource-server:8080
